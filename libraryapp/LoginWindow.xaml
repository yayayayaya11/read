<Window x:Class="libraryapp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход и регистрация" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#0F172A">
    <Grid>
        <Border Background="White" CornerRadius="14" Padding="16"
                Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TabControl Margin="0">
        <TabItem Header="Вход">
            <StackPanel Margin="8" VerticalAlignment="Center">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginLogin" Height="26"/>
                <TextBlock Text="Пароль" Margin="0,12,0,4"/>
                <PasswordBox x:Name="LoginPassword" Height="26"/>
                <Button Content="Войти" Margin="0,20,0,0" Height="32" Click="DoLogin"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Регистрация">
            <StackPanel Margin="8" VerticalAlignment="Center">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox x:Name="RegLogin" Height="26"/>
                <TextBlock Text="Пароль" Margin="0,8,0,4"/>
                <PasswordBox x:Name="RegPassword" Height="26"/>
                <TextBlock Text="Электронная почта" Margin="0,8,0,4"/>
                <TextBox x:Name="RegEmail" Height="26"/>
                <TextBlock Text="Отображаемое имя" Margin="0,8,0,4"/>
                <TextBox x:Name="RegName" Height="26"/>
                <Button Content="Зарегистрироваться" Margin="0,16,0,0" Height="32" Click="DoRegister"/>
            </StackPanel>
        </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
