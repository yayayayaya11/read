<Page x:Class="libraryapp.Pages.BookListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Списки" Loaded="Page_Loaded" Background="#F8FAFC">
    <DockPanel Margin="8" Background="#F8FAFC">
        <TabControl x:Name="Tabs" DockPanel.Dock="Top" SelectionChanged="Tabs_SelectionChanged">
            <TabItem Header="Заброшено" Tag="0"/>
            <TabItem Header="В планах" Tag="1"/>
            <TabItem Header="Читаю" Tag="2"/>
            <TabItem Header="Прочитано" Tag="3"/>
        </TabControl>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,8">
            <TextBox x:Name="SearchBox" Width="220" Height="26"/>
            <ComboBox x:Name="SortBox" Width="160" Height="26" Margin="8,0,0,0">
                <ComboBoxItem Content="Сортировка: название" Tag="title" IsSelected="True"/>
                <ComboBoxItem Content="Сортировка: оценка" Tag="rating"/>
            </ComboBox>
            <ComboBox x:Name="GenreBox" Width="180" Height="26" Margin="8,0,0,0"/>
            <Button Content="Обновить" Margin="8,0,0,0" Padding="12,2" Click="ReloadClick"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
