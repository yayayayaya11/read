<Page x:Class="libraryapp.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог" Loaded="Page_Loaded" Background="#F8FAFC">
    <DockPanel Margin="8" Background="#F8FAFC">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox" Width="220" Height="26" ToolTip="Поиск по названию или автору"/>
            <ComboBox x:Name="SortBox" Width="160" Height="26" Margin="8,0,0,0">
                <ComboBoxItem Content="Сортировка: название" Tag="title" IsSelected="True"/>
                <ComboBoxItem Content="Сортировка: оценка" Tag="rating"/>
            </ComboBox>
            <ComboBox x:Name="GenreBox" Width="180" Height="26" Margin="8,0,0,0"/>
            <Button Content="Обновить" Margin="8,0,0,0" Padding="12,2" Click="Refresh_Click"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
