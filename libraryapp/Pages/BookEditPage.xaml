<Page x:Class="libraryapp.Pages.BookEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Книга" Loaded="Page_Loaded" Background="#F8FAFC">
    <ScrollViewer Padding="12" Background="#F8FAFC">
        <StackPanel MaxWidth="800" x:Name="FormRoot">
            <TextBlock x:Name="TitleHeader" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
            <TextBlock Text="Название"/>
            <TextBox x:Name="FTitle" Height="28" Margin="0,4,0,8"/>
            <TextBlock Text="Краткое описание"/>
            <TextBox x:Name="FDescription" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8"/>
            <TextBlock Text="Текст книги (для чтения)"/>
            <TextBox x:Name="FFull" MinHeight="160" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,4,0,8"/>
            <TextBlock Text="Жанры"/>
            <ItemsControl x:Name="GenreList" Margin="0,4,0,8"/>
            <Button Content="Загрузить обложку (файл изображения)" HorizontalAlignment="Left" Click="PickCover_Click"/>
            <TextBlock x:Name="CoverInfo" Margin="0,4,0,8" Foreground="Gray"/>
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Сохранить" Padding="16,6" Click="Save_Click"/>
                <Button Content="Отмена" Margin="12,0,0,0" Padding="16,6" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
