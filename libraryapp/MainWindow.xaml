<Window x:Class="libraryapp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Библиотека" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <DockPanel Background="#F1F5F9">
        <Border x:Name="FreezeBanner" DockPanel.Dock="Top" Background="#7F1D1D" Padding="10" Visibility="Collapsed">
            <TextBlock Foreground="White" TextWrapping="Wrap"
                       Text="Ваш аккаунт заморожен. Некоторые действия могут быть ограничены. Подробности — в разделе «Профиль»."/>
        </Border>
        <Border DockPanel.Dock="Left" Width="56" Background="{StaticResource NavBg}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                    <Button Style="{StaticResource SidebarIconButton}" ToolTip="Профиль" Click="NavProfile">
                        <Viewbox Width="22" Height="22">
                            <Path Fill="White" Data="M12,12c2.21,0 4,-1.79 4,-4s-1.79,-4 -4,-4 -4,1.79 -4,4 1.79,4 4,4zM12,14c-2.67,0 -8,1.34 -8,4v2h16v-2c0,-2.66 -5.33,-4 -8,-4z"/>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource SidebarIconButton}" ToolTip="Выйти" Click="NavLogout">
                        <Viewbox Width="22" Height="22">
                            <!-- Иконка выхода (logout) -->
                            <Path Fill="White" Data="M10 17v-2H3v-4h7V9l5 4-5 4zm8-14H13v2h5v16h-5v2h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
                <StackPanel>
                    <Button Style="{StaticResource SidebarIconButton}" ToolTip="Каталог книг" Click="NavCatalog">
                        <Viewbox Width="22" Height="22">
                            <Path Fill="White" Data="M4,2 L20,2 20,22 4,22 Z M6,6 L18,6 M6,10 L14,10"/>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource SidebarIconButton}" ToolTip="Списки книг" Click="NavLists">
                        <Viewbox Width="22" Height="22">
                            <Path Fill="White" Data="M3,4 H21 V8 H3 Z M3,10 H21 V14 H3 Z M3,16 H21 V20 H3 Z"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnAdmin" Style="{StaticResource SidebarIconButton}" ToolTip="Администрирование" Click="NavAdmin" Visibility="Collapsed">
                        <Viewbox Width="22" Height="22">
                            <Path Fill="White" Data="M12,1 L3,5 V11 C3,16.55 6.84,21.74 12,23 17.16,21.74 21,16.55 21,11 V5 Z"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnAuthor" Style="{StaticResource SidebarIconButton}" ToolTip="Страница автора" Click="NavAuthor" Visibility="Collapsed">
                        <Viewbox Width="22" Height="22">
                            <Path Fill="White" Data="M3,17.25 V21 H21 V17.25 C21,15.45 16,14 12,14 8,14 3,15.45 3,17.25 M12,12 A4,4 0 1,0 12,4 A4,4 0 1,0 12,12 Z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
        <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden" Navigated="RootFrame_Navigated" Background="#F8FAFC"/>
    </DockPanel>
</Window>
